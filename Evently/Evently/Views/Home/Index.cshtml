@model List<Evently.Models.Events>

@{
    ViewData["Title"] = "DASHBOARD";

    var firstEvent = Model?.FirstOrDefault();
}

<div class="dashboard-wrap">

    <!-- STATS -->
    <div class="stats-row">

        <!-- TOTAL EVENTS -->
        <div class="stat-card">

            <div class="stat-icon">
                <i class="bi bi-calendar-week-fill"
                   style="color:#7c3aed;"></i>
            </div>

            <div class="stat-label">
                Total Events
            </div>

            <div class="stat-value">
                @ViewBag.TotalEvents
            </div>

        </div>

        <!-- ACTIVE EVENTS -->
        <div class="stat-card">

            <div class="stat-icon">
                <i class="bi bi-tags-fill"
                   style="color:#7c3aed;"></i>
            </div>

            <div class="stat-label">
                Active Events
            </div>

            <div class="stat-value">
                @ViewBag.ActiveEvents
            </div>

        </div>

    </div>

    <!-- MAIN -->
    <div class="bottom-row">

        <!-- RECENT EVENTS -->
        <div class="dash-card">

            <div class="dash-card-title">
                Recent Events
            </div>

            <table class="events-table">

                <thead>

                    <tr>
                        <th>Event</th>
                        <th>Date/Time</th>
                        <th>Venue</th>
                        <th>Status</th>
                    </tr>

                </thead>

                <tbody>

                    @if (Model != null && Model.Any())
                    {
                        @foreach (var e in Model)
                        {
                            <tr class="event-row"
                                onclick="selectEvent(
                                '@e.EventId',
                                '@e.EventName',
                                '@(e.Attendances?.Count() ?? 0)',
                                '@(e.Attendances?.Count(a =>
                                            a.Status ==
                                            Evently.Models.Attendances.AttendanceStatus.Present) ?? 0)',
                                '@(e.Attendances?.Count(a =>
                                            a.Status ==
                                            Evently.Models.Attendances.AttendanceStatus.Absent) ?? 0)'
                                )">

                                <td>
                                    @e.EventName
                                </td>

                                <td>
                                    @e.EventDate.ToString("MMM dd"),
                                    @e.StartTime.ToString(@"hh\:mm")
                                </td>

                                <td>
                                    @(string.IsNullOrEmpty(e.Venue)
                                        ? "—"
                                        : e.Venue)
                                </td>
                                <td>

                                    @{
                                        var badgeClass =
                                          e.Status == Evently.Models.Events.EventStatus.Scheduled
                                          ? "badge-scheduled"
                                          : e.Status == Evently.Models.Events.EventStatus.Ongoing
                                           ? "badge-ongoing"
                                          : e.Status == Evently.Models.Events.EventStatus.Completed
                                           ? "badge-completed"
                                         : "badge-cancelled";
                                      }

                                     <span class="badge @badgeClass">
                                    @e.Status
                               </span>

                            </td>

                            </tr>
                        }
                    }
                    else
                    {
                        <tr>

                            <td colspan="4"
                                style="text-align:center;">

                                No events found

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

        <!-- ATTENDANCE OVERVIEW -->
        <div class="dash-card att-card">

            <div class="dash-card-title">
                Attendance Overview
            </div>

            <!-- EVENT TITLE -->
            <div id="selectedEventName"
                 style="
                font-weight:800;
                margin-bottom:20px;
                color:#3b0764;
                font-size:1.05rem;
                ">

                @(firstEvent != null
                    ? firstEvent.EventName
                    : "No Event Selected")

            </div>

            <!-- MINI CARDS -->
            <div class="att-mini-row">

                <!-- PARTICIPANTS -->
                <div class="att-mini-card">

                    <div class="att-mini-icon">
                        <i class="bi bi-person-fill"
                           style="color:#7c3aed;"></i>
                    </div>

                    <div class="att-mini-label">
                        Participants
                    </div>

                    <div class="att-mini-value"
                         id="participantsCount">

                        0

                    </div>

                </div>

                <!-- ATTENDANCE RATE -->
                <div class="att-mini-card">

                    <div class="att-mini-icon">
                        <i class="bi bi-check-circle-fill"
                           style="color:#16a34a;"></i>
                    </div>

                    <div class="att-mini-label">
                        Attendance Rate
                    </div>

                    <div class="att-mini-value"
                         id="attendanceRate">

                        0%

                    </div>

                </div>

            </div>

            <!-- PRESENT -->
            <div class="att-row">

                <span class="att-label">
                    <i class="bi bi-person-check-fill me-2"
                       style="color:#16a34a;"></i>

                    Present
                </span>

                <span class="att-value"
                      id="presentCount">

                    0

                </span>

            </div>

            <!-- ABSENT -->
            <div class="att-row">

                <span class="att-label">
                    <i class="bi bi-person-x-fill me-2"
                       style="color:#dc2626;"></i>

                    Absent
                </span>

                <span class="att-value"
                      id="absentCount">

                    0

                </span>

            </div>

            <!-- BUTTON -->
            <a id="detailsBtn"
                   href="#"
                   class="btn-view">

                <i class="bi bi-eye-fill me-2"></i>

                View Details

            </a>

        </div>

    </div>

</div>

@section Styles {

    <link rel="stylesheet"
          href="~/css/dashboard.css"
          asp-append-version="true" />

}

@section Scripts {
    <script>

                function selectEvent(id, name, participants, present, absent) {

            document.getElementById("selectedEventName").innerText = name;

            participants = parseInt(participants);
            present = parseInt(present);
            absent = parseInt(absent);

            let rate = participants > 0
                ? Math.round((present / participants) * 100)
                : 0;

            document.getElementById("participantsCount").innerText = participants;

            document.getElementById("presentCount").innerText = present;

            document.getElementById("absentCount").innerText = absent;

            document.getElementById("attendanceRate").innerText = rate + "%";

            document.getElementById("detailsBtn").href =
                "/Events/AttendanceDetails/" + id;
        }

        window.onload = function () {

            const firstRow =
                document.querySelector(".event-row");

            if (firstRow) {
                firstRow.click();
            }
        };

    </script>
}