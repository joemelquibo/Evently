@{
    ViewBag.Title = "Calendars";
    Layout = null;

    /* ── Helpers ── */
    var today = DateTime.Today;
    int currentMonth = (int?)ViewBag.Month ?? today.Month;
    int currentYear = (int?)ViewBag.Year ?? today.Year;

    var firstDay = new DateTime(currentYear, currentMonth, 1);
    int daysInMonth = DateTime.DaysInMonth(currentYear, currentMonth);
    int startDayOfWeek = (int)firstDay.DayOfWeek; // 0=Sun

    string[] monthNames = { "January","February","March","April","May","June",
                            "July","August","September","October","November","December" };
    string[] dayNames = { "Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday" };

    /* Sample events — replace with ViewBag.Events / model binding */
    var events = new[]
    {
        new { Day = 18, Title = "Design Systems Summit 2026", Color = "#29B6F6" },
        new { Day = 19, Title = "Design Systems Summit 2026", Color = "#29B6F6" },
        new { Day = 20, Title = "Design Systems Summit 2026", Color = "#29B6F6" },
        new { Day = 18, Title = "Ai & Machine Learning Bootcamp", Color = "#F48FB1" },
        new { Day = 19, Title = "Ai & Machine Learning Bootcamp", Color = "#F48FB1" },
        new { Day = 20, Title = "Ai & Machine Learning Bootcamp", Color = "#F48FB1" },
        new { Day = 21, Title = "Ai & Machine Learning Bootcamp", Color = "#F48FB1" },
    };
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Evently – Calendar</title>

    <!-- Bootstrap 5 CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet" />

    <style>
        /* ── Root Variables ── */
        :root {
            --sidebar-bg:   #5B0DB8;
            --sidebar-w:    200px;
            --header-bg:    #7B1FD4;
            --main-bg:      #F4F0FB;
            --accent:       #8B2FE8;
            --accent-light: #C084FC;
            --text-light:   #EDE9FE;
            --text-muted:   #C4B5FD;
            --active-bg:    rgba(255,255,255,0.18);
            --card-bg:      #ffffff;
            --border-color: #E9E3F8;
            --dot-blue:     #29B6F6;
            --dot-pink:     #F48FB1;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Nunito', sans-serif;
            background: var(--main-bg);
            display: flex;
            height: 100vh;
            overflow: hidden;
        }

        /* ════════════ SIDEBAR ════════════ */
        .sidebar {
            width: var(--sidebar-w);
            background: var(--sidebar-bg);
            display: flex;
            flex-direction: column;
            padding: 24px 14px 24px;
            gap: 6px;
            flex-shrink: 0;
        }

        .sidebar-logo {
            font-size: 1.3rem;
            font-weight: 900;
            color: #fff;
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 28px;
            padding-left: 4px;
        }
        .sidebar-logo span { font-size: 1.4rem; }

        .sidebar-section-label {
            font-size: 0.65rem;
            font-weight: 800;
            letter-spacing: 0.12em;
            color: var(--text-muted);
            text-transform: uppercase;
            padding: 12px 4px 4px;
        }

        .sidebar-link {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 14px;
            border-radius: 12px;
            color: var(--text-light);
            font-weight: 700;
            font-size: 0.92rem;
            text-decoration: none;
            transition: background 0.2s;
        }
        .sidebar-link:hover { background: var(--active-bg); color: #fff; }
        .sidebar-link.active {
            background: rgba(255,255,255,0.22);
            color: #fff;
        }
        .sidebar-link i { font-size: 1.1rem; }

        .sidebar-spacer { flex: 1; }

        /* ════════════ MAIN AREA ════════════ */
        .main-wrap {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        /* ── Top Bar ── */
        .topbar {
            background: var(--header-bg);
            display: flex;
            align-items: center;
            padding: 16px 28px;
            gap: 16px;
        }
        .topbar-title {
            font-size: 1.8rem;
            font-weight: 900;
            color: #fff;
            letter-spacing: 0.04em;
            flex: 1;
        }
        .topbar-search {
            background: #fff;
            border-radius: 20px;
            display: flex;
            align-items: center;
            padding: 6px 16px;
            gap: 8px;
            min-width: 220px;
        }
        .topbar-search input {
            border: none;
            outline: none;
            font-family: 'Nunito', sans-serif;
            font-size: 0.88rem;
            color: #555;
            background: transparent;
            width: 100%;
        }
        .topbar-search i { color: #888; }
        .topbar-icon {
            color: #fff;
            font-size: 1.4rem;
            cursor: pointer;
            padding: 4px 6px;
            border-radius: 8px;
            transition: background 0.2s;
        }
        .topbar-icon:hover { background: var(--active-bg); }

        /* ════════════ CONTENT BODY ════════════ */
        .content-body {
            flex: 1;
            display: flex;
            overflow: hidden;
            padding: 20px;
            gap: 16px;
        }

        /* ── Events Sidebar ── */
        .events-panel {
            width: 160px;
            flex-shrink: 0;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }
        .events-panel-title {
            display: flex;
            align-items: center;
            gap: 8px;
            font-weight: 800;
            font-size: 0.95rem;
            color: #444;
            margin-bottom: 4px;
        }
        .events-panel-title i { color: var(--accent); font-size: 1.1rem; }

        .event-card {
            border-radius: 12px;
            padding: 10px 12px;
            font-size: 0.75rem;
            font-weight: 700;
            line-height: 1.35;
        }
        .event-card.blue-card {
            background: #DBEAFE;
            color: #1565C0;
            border-left: 3px solid #29B6F6;
        }
        .event-card.pink-card {
            background: #FCE4EC;
            color: #880E4F;
            border-left: 3px solid #F48FB1;
        }
        .event-card .edate {
            font-size: 0.68rem;
            font-weight: 600;
            opacity: 0.7;
            margin-bottom: 2px;
        }

        /* ── Calendar Panel ── */
        .calendar-panel {
            flex: 1;
            background: var(--card-bg);
            border-radius: 16px;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            box-shadow: 0 2px 12px rgba(91,13,184,0.07);
        }

        /* Month Tab Bar */
        .month-tabs {
            display: flex;
            border-bottom: 2px solid var(--border-color);
            overflow-x: auto;
            padding: 0 8px;
            scrollbar-width: none;
        }
        .month-tabs::-webkit-scrollbar { display: none; }

        .month-tab {
            padding: 10px 14px;
            font-size: 0.8rem;
            font-weight: 700;
            color: #888;
            cursor: pointer;
            border-bottom: 3px solid transparent;
            margin-bottom: -2px;
            white-space: nowrap;
            text-decoration: none;
            transition: color 0.2s;
        }
        .month-tab:hover { color: var(--accent); }
        .month-tab.active {
            color: #fff;
            background: var(--accent);
            border-radius: 20px;
            border-bottom: 3px solid transparent;
            padding: 6px 14px;
            margin: 6px 2px;
        }

        /* Day Headers */
        .cal-header {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            border-bottom: 1px solid var(--border-color);
        }
        .cal-header-cell {
            padding: 8px 4px;
            text-align: center;
            font-size: 0.78rem;
            font-weight: 800;
            color: #666;
            letter-spacing: 0.03em;
        }

        /* Grid */
        .cal-grid {
            flex: 1;
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            grid-auto-rows: 1fr;
            overflow: hidden;
        }

        .cal-cell {
            border-right: 1px solid var(--border-color);
            border-bottom: 1px solid var(--border-color);
            padding: 6px 8px;
            min-height: 80px;
            font-size: 0.8rem;
            position: relative;
            vertical-align: top;
        }
        .cal-cell:nth-child(7n) { border-right: none; }

        .cal-day-num {
            font-weight: 700;
            color: #333;
            font-size: 0.85rem;
            margin-bottom: 4px;
        }
        .cal-cell.other-month .cal-day-num { color: #bbb; }
        .cal-cell.today .cal-day-num {
            background: var(--accent);
            color: #fff;
            width: 24px;
            height: 24px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.78rem;
        }

        .cal-event {
            display: flex;
            align-items: flex-start;
            gap: 4px;
            margin-bottom: 2px;
            font-size: 0.67rem;
            font-weight: 600;
            line-height: 1.3;
            color: #444;
            overflow: hidden;
        }
        .cal-event-dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            flex-shrink: 0;
            margin-top: 2px;
        }
        .cal-event-text {
            overflow: hidden;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
        }
    </style>
</head>
<body>

    <!-- ══════════ SIDEBAR ══════════ -->
    <aside class="sidebar">
        <div class="sidebar-logo">
            Evently <span>🎉</span>
        </div>

        <div class="sidebar-section-label">Overview</div>

        <a href="#" class="sidebar-link">
            <i class="bi bi-house-door-fill"></i> Dashboard
        </a>
        <a href="#" class="sidebar-link">
            <i class="bi bi-check2-square"></i> Events
        </a>
        <a href="#" class="sidebar-link active">
            <i class="bi bi-calendar3"></i> Calendar
        </a>

        <div class="sidebar-spacer"></div>

        <div class="sidebar-section-label">System</div>
        <a href="#" class="sidebar-link">
            <i class="bi bi-person-fill"></i> Accounts
        </a>
        <a href="#" class="sidebar-link">
            <i class="bi bi-gear-fill"></i> Settings
        </a>
    </aside>

    <!-- ══════════ MAIN ══════════ -->
    <div class="main-wrap">

        <!-- Top Bar -->
        <div class="topbar">
            <div class="topbar-title">CALENDAR</div>
            <div class="topbar-search">
                <i class="bi bi-search"></i>
                <input type="text" placeholder="Search..." />
            </div>
            <i class="bi bi-bell topbar-icon"></i>
            <i class="bi bi-box-arrow-right topbar-icon"></i>
        </div>

        <!-- Content -->
        <div class="content-body">

            <!-- Events Sidebar -->
            <div class="events-panel">
                <div class="events-panel-title">
                    <i class="bi bi-calendar3"></i> Events
                </div>

                <div class="event-card blue-card">
                    <div class="edate">Mar 18-20, 2026</div>
                    Design Systems Summit 2026
                </div>

                <div class="event-card pink-card">
                    <div class="edate">Mar 18-21, 2026</div>
                    Design Systems Summit 2026
                </div>
            </div>

            <!-- Calendar -->
            <div class="calendar-panel">

                <!-- Month Tabs -->
                <div class="month-tabs">
                    @for (int m = 1; m <= 12; m++)
                    {
                        string tabClass = (m == currentMonth) ? "month-tab active" : "month-tab";
                        <a href="@Url.Action("Calendar", new { month = m, year = currentYear })"
                           class="@tabClass">@monthNames[m - 1]</a>
                    }
                </div>

                <!-- Day Headers -->
                <div class="cal-header">
                    @foreach (var d in dayNames)
                    {
                        <div class="cal-header-cell">@d</div>
                    }
                </div>

                <!-- Calendar Grid -->
                <div class="cal-grid">
                    @{
                        /* Cells before first day (previous month) */
                        var prevMonth = firstDay.AddMonths(-1);
                        int prevDaysTotal = DateTime.DaysInMonth(prevMonth.Year, prevMonth.Month);

                        for (int i = 0; i < startDayOfWeek; i++)
                        {
                            int prevDay = prevDaysTotal - startDayOfWeek + 1 + i;
                            <div class="cal-cell other-month">
                                <div class="cal-day-num">@prevDay</div>
                            </div>
                        }

                        /* Current month cells */
                        for (int day = 1; day <= daysInMonth; day++)
                        {
                            bool isToday = (day == today.Day && currentMonth == today.Month && currentYear == today.Year);
                            string cellClass = isToday ? "cal-cell today" : "cal-cell";

                            <div class="@cellClass">
                                <div class="cal-day-num">@day</div>
                                @foreach (var ev in events.Where(e => e.Day == day))
                                {
                                    <div class="cal-event">
                                        <div class="cal-event-dot" style="background:@ev.Color"></div>
                                        <div class="cal-event-text">@ev.Title</div>
                                    </div>
                                }
                            </div>
                        }

                        /* Fill remaining cells (next month) */
                        int totalCells = startDayOfWeek + daysInMonth;
                        int remainingCells = (totalCells % 7 == 0) ? 0 : 7 - (totalCells % 7);

                        for (int i = 1; i <= remainingCells; i++)
                        {
                            <div class="cal-cell other-month">
                                <div class="cal-day-num">@i</div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
