@model Evently.Models.Events

@{
    ViewData["Title"] = "Create Event";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .event-card {
        background-color: #E7DBFF; /* Light purple background */
        border-radius: 20px;
        border: none;
        margin-bottom: 20px;
        padding: 20px;
    }

    .form-label {
        font-weight: 600;
        color: #4A4A4A;
        font-size: 0.9rem;
    }

    .form-control, .form-select {
        border-radius: 10px;
        border: 1px solid #D1C4E9;
        padding: 10px;
    }

    .section-title {
        font-weight: 800;
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 20px;
    }

    .btn-create {
        background-color: #B2FF59;
        color: #2e7d32;
        font-weight: bold;
        border-radius: 12px;
        padding: 10px 25px;
        border: none;
    }

    .btn-draft {
        background-color: #000;
        color: #fff;
        border-radius: 12px;
        padding: 10px 25px;
    }
</style>

<div class="container-fluid py-4">
    <form asp-controller="Events" asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <div class="row">
            <div class="col-lg-7">
                <div class="event-card shadow-sm">
                    <div class="section-title">
                        <span class="fs-4">💡</span> Basic Information
                    </div>
                    <div class="mb-3">
                        <label asp-for="EventName" class="form-label">Event Title</label>
                        <input asp-for="EventName" class="form-control" placeholder="Event Title" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="4" placeholder="Description"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Category / Type</label>
                        <select class="form-select">
                            <option>Conference</option>
                            <option>Workshop</option>
                            <option>Seminar</option>
                        </select>
                    </div>
                </div>

                <div class="event-card shadow-sm">
                    <div class="section-title">
                        <span class="fs-4">📅</span> Date / Time
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="EventDate" class="form-label">Start Date</label>
                            <input asp-for="EventDate" type="date" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">End Date</label>
                            <input type="date" class="form-control" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="StartTime" class="form-label">Start Time</label>
                            <input asp-for="StartTime" type="time" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="EndTime" class="form-label">End Time</label>
                            <input asp-for="EndTime" type="time" class="form-control" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="event-card shadow-sm">
                    <div class="section-title">
                        <span class="fs-4">📍</span> Location
                    </div>
                    <div class="mb-3">
                        <label asp-for="Venue" class="form-label">Venue / Address</label>
                        <input asp-for="Venue" class="form-control" placeholder="Venue / Address" />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="event-card shadow-sm">
                            <div class="section-title">
                                <span class="fs-4">👥</span> Capacity
                            </div>
                            <label asp-for="Capacity" class="form-label">Max Participants</label>
                            <input asp-for="Capacity" class="form-control" type="number" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="event-card shadow-sm">
                            <div class="section-title">
                                <span class="fs-4">➕</span> Registration
                            </div>
                            <label class="form-label">Price / Fee (Optional)</label>
                            <input type="text" class="form-control" placeholder="₱" />
                        </div>
                    </div>
                </div>

                <div class="event-card shadow-sm">
                    <div class="section-title">
                        <span class="fs-4">👤</span> Organizer Info
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Organizer Name</label>
                        <input type="text" class="form-control" placeholder="Name" />
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Email</label>
                            <input type="email" class="form-control" placeholder="done@xxx.com" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Phone</label>
                            <input type="text" class="form-control" placeholder="09** *** ****" />
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-between mt-4 pb-5">
            <a asp-controller="Events" asp-action="Index" class="btn btn-light rounded-pill px-4">❌ Cancel</a>
            <div class="d-flex gap-2">
                <button type="button" class="btn btn-draft shadow-sm">💾 Save as Draft</button>
                <button type="submit" class="btn btn-create shadow-sm">✅ Create Event</button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}