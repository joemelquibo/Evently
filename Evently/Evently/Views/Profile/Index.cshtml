@model Evently.Models.ProfileViewModel
@{
    ViewData["Title"] = "Profile";
}




<div class="profile-page">

    <!-- Success message -->
    @if (TempData["Success"] != null)
    {
        <div class="alert-success">@TempData["Success"]</div>
    }

    <!-- Main card -->
    <div class="content-card">

        <!-- Profile banner -->
        <div class="profile-banner">
            <div class="avatar-wrapper">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" alt="Profile" class="avatar-img" />
                }
                else
                {
                    <svg width="38" height="38" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z" />
                    </svg>
                }
            </div>

            <div class="profile-info">
                <h2>@Model.FirstName @Model.LastName</h2>
                <div class="email">@Model.Email</div>
                <div class="phone">@Model.Phone</div>
                <div class="badges">
                    <span class="badge badge-role">@Model.Role</span>
                    <span class="badge badge-events">@Model.EventCount Events</span>
                </div>
            </div>

            <div style="display:flex; flex-direction:column; gap:8px;">
                <a asp-action="Edit" asp-controller="Profile" class="edit-profile-btn">
                    Edit Profile
                </a>
                <a asp-action="CashIn" asp-controller="Profile" class="cash-in-btn">
                    Cash In
                </a>
            </div>
        </div>

        <!-- Form fields (read-only display; wrap in a form for editing) -->
        <div class="form-section">
            <div class="form-grid">
                <div class="form-group">
                    <label>First Name</label>
                    <input type="text" value="@Model.FirstName" readonly />
                </div>
                <div class="form-group">
                    <label>Last Name</label>
                    <input type="text" value="@Model.LastName" readonly />
                </div>
                <div class="form-group">
                    <label>Email Address</label>
                    <input type="email" value="@Model.Email" readonly />
                </div>
                <div class="form-group">
                    <label>Phone</label>
                    <input type="text" value="@Model.Phone" readonly />
                </div>
            </div>
        </div>

        <!-- Events history -->
        <div class="events-section">
            <h3>Events History</h3>
            <table class="events-table">
                <thead>
                    <tr>
                        <th>Event</th>
                        <th>Date</th>
                        <th>Status</th>
                        <th>Attendance</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ev in Model.EventHistory)
                    {
                        <tr>
                            <td>@ev.Name</td>
                            <td>@ev.Date</td>
                            <td>
                                @{
                                    var statusClass = ev.Status == "Upcoming" ? "pill-upcoming" : "pill-ended";
                                }
                                <span class="pill @statusClass">@ev.Status</span>
                            </td>
                            <td>
                                @{
                                    string attendanceClass = ev.Attendance switch
                                    {
                                                                            "Yes" => "pill-yes",
                                                                            "No" => "pill-no",
                                        _ => "pill-undetermined"
                                    };
                                    string attendanceLabel = ev.Attendance switch
                                    {
                                                                            "Yes" => "✓ Yes",
                                                                            "No" => "✗ No",
                                        _ => ev.Attendance
                                    };
                                }
                                <span class="pill @attendanceClass">@attendanceLabel</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/profile.css" asp-append-version="true" />
}
