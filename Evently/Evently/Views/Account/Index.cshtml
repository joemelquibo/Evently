@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Evently | Sign In</title>
    <link rel="stylesheet" href="https://www.w3schools.com/w3css/4/w3.css">

    <style>
        :root {
            --bg-dark: #0d0b21;
            --bg-purple: #3e1f81;
            --btn-purple: #7d2ae8;
        }

        body, html {
            height: 100%;
            margin: 0;
            overflow: hidden;
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            /* Vibrant Purple Beam Gradient */
            background: radial-gradient(circle at 30% 50%, var(--bg-purple) 0%, var(--bg-dark) 70%, #000 100%);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .auth-container {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 120px; /* Large gap for wider elements */
            width: 100%;
            max-width: 1400px;
            padding: 40px;
        }

        /* 1. THIN RAINBOW BORDER & WIDE LOGO BOX */
        .brand-border-wrap {
            padding: 3px; /* Very thin rainbow edge */
            border-radius: 50%;
            background: linear-gradient(45deg, #fbca11, #ff007a, #7d2ae8, #00d4ff);
            box-shadow: 0 0 60px rgba(125, 42, 232, 0.4);
        }

        .brand-circle {
            width: 500px; /* Large, wide circle */
            height: 500px;
            background: #ffffff;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            position: relative;
        }

        .placeholder-text {
            font-size: 4rem;
            font-weight: 800;
            color: #ececec;
            text-transform: uppercase;
            letter-spacing: 8px;
        }

        /* 2. WIDER LOGIN CARD */
        .login-card {
            width: 550px;
            max-width 550px; /* Wide form factor */
            border-radius: 25px !important;
            overflow: hidden;
            border: none;
            box-shadow: 0 60px 90px rgba(0,0,0,0.6);
        }

        .card-header-vibrant {
            /* Matched gradient from your image */
            background: linear-gradient(90deg, #4b0082 0%, #8a2be2 100%);
            padding: 40px;
            color: white;
            font-weight: bold;
            font-size: 1.8rem;
            letter-spacing: 1px;
        }

        .form-content {
            padding: 50px 60px !important; /* Wide internal spacing */
        }

        .label-text {
            font-size: 0.85rem;
            font-weight: 800;
            color: #6c757d;
            display: block;
            margin-bottom: 10px;
            text-transform: uppercase;
        }

        .w3-input {
            border: 1.5px solid #eee !important;
            padding: 15px !important;
            border-radius: 12px !important;
            margin-bottom: 30px;
            font-size: 1rem;
            background-color: #fafafa !important;
        }

        .btn-signin {
            background-color: var(--btn-purple) !important;
            color: white !important;
            border-radius: 12px !important;
            font-weight: bold;
            padding: 16px !important;
            font-size: 1.2rem;
            margin-top: 10px;
            box-shadow: 0 4px 15px rgba(125, 42, 232, 0.3);
        }

        .signup-link {
            color: #8a2be2;
            text-decoration: none;
            font-weight: bold;
        }
    </style>
</head>
<body>

    <div class="auth-container">

        <div class="brand-border-wrap">
            <div class="brand-circle">
                <div class="placeholder-text">Logo</div>
            </div>
        </div>

        <div class="login-card w3-card w3-white">
            <div class="card-header-vibrant">
                SIGN IN
            </div>

            <div class="form-content">
                <form method="post">
                    <label class="label-text">Email Address</label>
                    <input type="email" name="email" class="w3-input" placeholder="name@email.com" required>

                    <label class="label-text">Password</label>
                    <input type="password" name="password" class="w3-input" placeholder="Enter password" required>

                    <div style="margin-bottom: 25px;">
                        <a href="#" style="color: #8a2be2; text-decoration: none; font-weight: bold; font-size: 0.9rem;">Forgot password?</a>
                    </div>

                    <button type="submit" class="w3-button w3-block btn-signin shadow">Sign In</button>

                    <div class="w3-center w3-margin-top" style="font-size: 1rem; color: #888;">
                        Don't have an account?
                        <a asp-controller="Account" asp-action="Register" class="signup-link">Sign Up</a>
                    </div>
                </form>
            </div>
        </div>

    </div>
</body>
</html>